{
  "name": "brick-builder",
  "version": "0.0.0",
  "private": true,
  "description": "Procedural LEGO-style 3D editor with realtime multiplayer",
  "author": "Neko Media",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "dev:web": "pnpm --filter @brick/web dev",
    "dev:server": "pnpm --filter @brick/server dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
