# dependencies
node_modules/
.pnpm-store/

# build outputs
dist/
build/
*.tsbuildinfo

# env / local config
# .env files are OK to commit when they only hold publishable client-side
# config (e.g. a Supabase anon key). Per-developer overrides belong in
# .env.local which stays uncommitted.
.env.local
.env.*.local

# editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# runtime / data
*.sqlite
*.sqlite-journal
/apps/server/data/

# coverage
coverage/
